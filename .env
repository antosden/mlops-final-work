# PostgreSQL
POSTGRES_DB=mlops_deduplication
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=mlflow-artifacts

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# FastAPI
HOST=0.0.0.0
PORT=8000

# Model settings
MODEL_NAME=flocktory_profile_deduplication_model
PRODUCTION_STAGE=Production
CANDIDATE_STAGE=Staging

# Quality gate
MIN_PRECISION=0.90
MIN_F1_DELTA=0.00